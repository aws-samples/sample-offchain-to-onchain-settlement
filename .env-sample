# Deployer wallet private key (0x-prefixed) used by Foundry scripts
PRIVATE_KEY=0x

# AWS deployment region and target chain
AWS_REGION=us-east-1
CHAIN_ID=11155111
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# CRE simulation/deploy network routing.
# chain-name must match CRE SDK EVM client names (see Chainlink CRE EVM client docs).
CRE_CHAIN_NAME=ethereum-testnet-sepolia
# Sepolia default selector; override for other networks (e.g., ETH mainnet,
# Base Sepolia, Base mainnet, etc.).
CHAIN_SELECTOR=16015286601757825753

## KeystoneForwarder for Sepolia ETH (update this when targeting a different chain).
KEYSTONE_FORWARDER=0x15fC6ae953E024d975e77382eEeC56A9101f9F88

# Populated by deployment scripts after infra/contracts deployment
KMS_SIGNER=
KEY_REGISTRY=
SETTLEMENT_CONSUMER=
TOKEN=
